{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Site Data Schema",
  "type": "object",
  "required": ["global", "categories", "authors", "articles"],
  "properties": {
    "global": {
      "type": "object",
      "properties": {
        "siteName": { "type": "string" },
        "defaultSeo": {
          "type": "object",
          "properties": {
            "metaTitle": { "type": "string" },
            "metaDescription": { "type": "string" },
            "shareImage": { "type": ["string", "null"] }
          },
          "required": ["metaTitle", "metaDescription"]
        },
        "siteDescription": { "type": "string" },
        "favicon": { "type": ["string", "null"] }
      }
    },
    "about": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "blocks": { "type": "array", "items": { "$ref": "#/definitions/block" } }
      }
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "slug"],
        "properties": { "name": { "type": "string" }, "slug": { "type": "string" } }
      }
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string" },
          "avatar": { "type": "string" }
        }
      }
    },
    "articles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "slug", "category", "author", "description", "blocks"],
        "properties": {
          "title": { "type": "string" },
          "slug": { "type": "string" },
          "category": { "type": "object", "properties": { "id": { "type": "integer" } } },
          "author": { "type": "object", "properties": { "id": { "type": "integer" } } },
          "description": { "type": "string" },
          "cover": { "type": ["string", "null"] },
          "blocks": { "type": "array", "items": { "$ref": "#/definitions/block" } }
        }
      }
    }
  },
  "definitions": {
    "block": {
      "type": "object",
      "required": ["__component"],
      "properties": { "__component": { "type": "string" } },
      "allOf": [
        {
          "if": { "properties": { "__component": { "const": "shared.quote" } } },
          "then": {
            "properties": { "title": { "type": "string" }, "body": { "type": "string" } },
            "required": ["title", "body"]
          }
        },
        {
          "if": { "properties": { "__component": { "const": "shared.rich-text" } } },
          "then": { "properties": { "body": { "type": "string" } }, "required": ["body"] }
        },
        {
          "if": { "properties": { "__component": { "const": "shared.media" } } },
          "then": { "properties": { "file": { "type": "string" } }, "required": ["file"] }
        },
        {
          "if": { "properties": { "__component": { "const": "shared.slider" } } },
          "then": { "properties": { "files": { "type": "array", "items": { "type": "string" } } }, "required": ["files"] }
        }
      ]
    }
  }
}
